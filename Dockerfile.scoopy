# Dockerfile.scoopy — Cloud-ready build for Scoopy (Scoop Patrol Agent Zero fork)
#
# Uses the pre-built Agent Zero base image which already contains all heavy ML deps
# (torch, transformers, sentence-transformers, whisper, kokoro, faiss, etc.)
#
# Key insight: install_A0.sh runs `python preload.py --dockerized=true` at the end
# of the build step. preload.py tries to import every ML package at once, which
# fails if any package is not in the active build-time venv.
#
# Solution: patch install_A0.sh to skip the preload.py step during the Docker build.
# The app will preload models on first startup instead — identical runtime behaviour.
#
# BRANCH=local tells install_A0.sh to use the files we COPY in (our fork),
# rather than cloning from the upstream agent0ai/agent-zero repo.

FROM agent0ai/agent-zero-base:latest

ARG BRANCH=local
ENV BRANCH=$BRANCH

# Copy the Docker runtime filesystem (startup scripts, nginx, supervisord, etc.)
COPY ./docker/run/fs/ /

# Copy our entire fork (including plugins/scoopy/ and knowledge/scoopy/) into
# the location the startup scripts expect
COPY ./ /git/agent-zero

# Patch install_A0.sh to skip the preload.py step during Docker build.
# preload.py warms up model caches — useful at runtime but breaks the build
# because it imports every ML package into the build-time venv.
# The app preloads on first startup instead (identical behaviour).
RUN sed -i 's|python /git/agent-zero/preload.py --dockerized=true|echo "Skipping preload.py at build time — will run on first startup"|g' /ins/install_A0.sh

# Pre-install steps (apt update, SSH setup)
RUN bash /ins/pre_install.sh $BRANCH

# Install Agent Zero Python packages and playwright
# Heavy ML deps are already in the base image — uv resolves them quickly
RUN bash /ins/install_A0.sh $BRANCH

# Install additional system software (LibreOffice, xpra, etc.)
#
# Made non-fatal 2026-07-22. This step broke the build with an apt conflict that
# is not ours and that we cannot fix from here:
#
#   xpra-x11 : Depends: python3 (>= 3.14~) but 3.13.7-1+b1 is to be installed
#   E: Unable to satisfy dependencies. Reached two conflicting assignments
#
# xpra's apt repository has moved to packages built against Python 3.14, while
# agent0ai/agent-zero-base ships 3.13.7. Upstream drifted out from under the
# base image, so this will keep failing until the base image catches up.
#
# What it costs us: xpra is a remote-desktop server for Agent Zero's visual
# desktop feature, and this script also pulls LibreOffice for document
# conversion. Scoopy's job is CRM reads and writes, billing, routing and
# customer messages. He needs neither. Browser automation uses Playwright,
# installed by install_A0.sh above, not xpra.
#
# `|| true` rather than deleting the line, so that if the upstream conflict is
# ever resolved the step starts working again on its own with no edit here.
# Same spirit as the preload.py patch further up: skip what the cloud build
# cannot do, keep everything that matters.
RUN bash /ins/install_additional.sh $BRANCH || \
    echo "WARNING: install_additional.sh failed; continuing without xpra/LibreOffice"

# Second install pass (cleans up and re-installs A0 without pip cache)
ARG CACHE_DATE=none
RUN echo "cache buster $CACHE_DATE" && bash /ins/install_A02.sh $BRANCH

# Post-install steps
RUN bash /ins/post_install.sh $BRANCH

# Pre-copy fork files to /a0 at BUILD TIME so startup is instant
# (no cp at runtime = Flask starts in <1 second, well within Render's health check window)
RUN cp -rn --no-preserve=ownership,mode /git/agent-zero/. /a0

# Stash a pristine copy of usr/ OUTSIDE the disk mount point.
#
# Render mounts the persistent disk at /a0/usr, which shadows everything the
# image put there. The tree is empty in git (only .gitkeep files), but the
# directories themselves are load-bearing: helpers/plugins.py:230 iterdir()s
# /a0/usr/plugins with no existence check, so a missing directory crashes the
# container on startup rather than degrading. Observed 2026-07-22 as a restart
# loop the moment the disk was first attached.
#
# start_render.sh seeds from here on boot, no-clobber.
RUN cp -a /a0/usr /a0-usr-skel && ls -1 /a0-usr-skel

EXPOSE 10000

RUN chmod +x /exe/initialize.sh /exe/run_A0.sh /exe/run_searxng.sh /exe/run_tunnel_api.sh /exe/start_render.sh

# Render-specific startup: bypass supervisord, run run_ui.py directly on port 10000
CMD ["/exe/start_render.sh"]
